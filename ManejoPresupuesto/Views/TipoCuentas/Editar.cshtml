@model TipoCuenta

@{
    ViewData["Title"] = "Editar Tipo Cuenta";
}

<h1>Editar tipo cuenta @Model.NombreTipoCuenta</h1>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<form asp-action="Editar">
    <input type="hidden" asp-for="TipoCuenta_Id" />
    <div class="mb-3">
        <label asp-for="NombreTipoCuenta" class="form-label"></label>
        <input type="text" asp-for="NombreTipoCuenta" class="form-control" />
        <span asp-validation-for="NombreTipoCuenta" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Enviar</button>
    <a class="btn btn-secondary" asp-action="Index">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}