@model Categoria

@{
    ViewData["Title"] = "Crear Categoria";
}

<h1>Crear Categoria</h1>
<h5>
    La categoría nos permite indicar en qué gastamos nuestro dinero,
    también, de dónde provienen nuestros ingresos.
</h5>

<form asp-action="Crear">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="NombreCategoria" class="form-label"></label>
        <input asp-for="NombreCategoria" class="form-control"/>
        <span asp-validation-for="NombreCategoria" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="IdTipoTransaccion" class="form-label"></label>
        <select asp-for="IdTipoTransaccion" asp-items="Html.GetEnumSelectList<TipoTransaccion>()" class="form-select"></select>
        <span asp-validation-for="IdTipoTransaccion" class="text-danger"></span>
    </div>

    <button class="btn btn-primary">Enviar</button>
    <a class="btn btn-secondary" asp-action="Index">Cancelar</a>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}